# Redis
REDIS_URL=redis://localhost:6379

# Firebase
FIREBASE_PROJECT_ID=your-project-id
# Option 1: Minified JSON (use single quotes around the value)
# FIREBASE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'
# Option 2: Base64 encoded (recommended - no escaping needed)
# Generate with: cat serviceAccountKey.json | base64 -w 0
FIREBASE_SERVICE_ACCOUNT_JSON=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...

# AWS S3
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-northeast-2
VIDEOS_BUCKET=your-bucket-name
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# Provider API Keys (fallback - users can provide their own)
SORA_API_KEY=sk-...
GEMINI_API_KEY=...
GROK_API_KEY=...

# Application
DEBUG=false
LOG_LEVEL=INFO
MAX_CONCURRENT_JOBS_PER_PROJECT=10

# Internal service auth (shared secret with Next.js frontend)
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_SECRET=your-secret-key-here