// Add a function to check if device is mobile
const isMobile = () => {
  return /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
};

// Only initialize Lenis if not on mobile
const lenisRef = !isMobile() ? new Lenis({
  duration: 1.2,
  easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
  orientation: 'vertical',
  gestureOrientation: 'vertical',
  smoothWheel: true,
  smoothTouch: false,
  touchMultiplier: 2,
}) : null;

// Modify your raf function to only run if lenisRef exists
function raf(time) {
  if (lenisRef) {
    lenisRef.raf(time);
  }
  requestAnimationFrame(raf);
}

requestAnimationFrame(raf); 